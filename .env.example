# Copy to .env.local and fill in values. Never commit real secrets.

# Neon Postgres connection string (Vercel Marketplace → Neon).
# Leave as placeholder (or unset) to use local file store at data/local-store.json for single-machine dev.
# For cross-device sync in production, set a real Neon URL and run: npm run db:migrate
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Random secret for signing session cookies (e.g. openssl rand -base64 32)
SESSION_SECRET=change-me-to-a-long-random-string

# Bootstraps the first admin if no admin user exists yet
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
